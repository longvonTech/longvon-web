# 复制为 .env 后填入真实值，禁止提交 .env 到版本库

# ---- Database ----
# 注意：本地开发使用docker-compose中的postgres服务
DATABASE_URL="postgresql://mateyou:mateyou_dev_password@localhost:5432/mateyou?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- Auth (Identity Service) ----
# 对应authentication-architecture-v1.md：Access 15分钟 / Refresh 30天(Web)
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- API ----
API_PORT=4000
# 注意：必须用NEXT_PUBLIC_前缀，否则Next.js不会把这个变量打包进浏览器端代码
# （详见apps/web/lib/api-client.ts的说明）
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
# 前端自身的访问地址，供后端CORS白名单使用（与上面NEXT_PUBLIC_API_BASE_URL是两个不同方向的地址，不要混用）
WEB_APP_URL="http://localhost:3000"
# 站点的最终公开访问域名，用于生成sitemap.xml/canonical标签/OpenGraph绝对URL等SEO相关输出。
# 本地开发环境填localhost即可，生产环境必须替换为www.longvon.com（呼应alicloud-deployment-v1.md）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Strapi CMS (占位，Sprint 1未实际接线，见apps/cms/README.md) ----
STRAPI_PORT=1337
STRAPI_APP_KEYS="replace-me"
STRAPI_API_TOKEN_SALT="replace-me"
STRAPI_ADMIN_JWT_SECRET="replace-me"
STRAPI_JWT_SECRET="replace-me"
