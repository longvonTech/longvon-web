# ============================================================
# MATEYOU Platform — Production Environment Variables
# 文件：.env.production.example
# 用途：复制为 .env.production 后填入真实值，永远不要把真实值提交到 git
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=mateyou
POSTGRES_PASSWORD=请替换为高强度随机密码_至少32位
POSTGRES_DB=mateyou_prod

# ---- Redis ----
REDIS_PASSWORD=请替换为高强度随机密码_至少32位
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ---- NestJS API ----
API_PORT=4000
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# JWT 密钥——两个密钥必须不同，均应为64位以上随机字符串
JWT_ACCESS_SECRET=请替换为随机字符串_至少64位
JWT_REFRESH_SECRET=请替换为另一个随机字符串_至少64位_必须与ACCESS不同
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- Next.js Web ----
# 生产站点URL（不带尾部斜杠）
NEXT_PUBLIC_SITE_URL=https://www.longvon.com
# 前端调用API的基础URL（如果Nginx做了统一代理可设为同域名下的/api前缀路径）
NEXT_PUBLIC_API_BASE_URL=https://www.longvon.com/api
WEB_APP_URL=https://www.longvon.com

# ---- 百度生态（Sprint 8 中国市场 SEO）----
# 百度统计网站ID（在 https://tongji.baidu.com 中获取）
NEXT_PUBLIC_BAIDU_TONGJI_ID=请填入百度统计ID_32位十六进制
# 百度搜索资源平台站点验证码（在 https://ziyuan.baidu.com 中获取）
NEXT_PUBLIC_BAIDU_VERIFICATION=请填入百度验证码

# 百度主动推送 Token（在百度搜索资源平台→链接提交→API推送中获取）
BAIDU_PUSH_TOKEN=请填入百度推送Token

# ---- 阿里云（可选，用于OSS图片存储等）----
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_REGION=oss-cn-shenzhen

# ---- 短信服务（OTP，Sprint 1 目前为开发日志模式）----
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=MATEYOU
# ALIYUN_SMS_TEMPLATE_CODE=SMS_XXXXXXXXX
