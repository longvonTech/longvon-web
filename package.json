{
  "name": "mateyou-platform",
  "private": true,
  "version": "0.1.0",
  "description": "MATEYOU AI Digital Health Platform - Monorepo",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/database"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=packages/database && npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web && npm run lint --workspace=apps/api",
    "test": "npm run test --workspace=apps/api",
    "db:generate": "npm run generate --workspace=packages/database",
    "db:migrate:dev": "npm run migrate:dev --workspace=packages/database",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=packages/database",
    "db:seed": "npm run seed --workspace=packages/database",
    "db:studio": "npm run studio --workspace=packages/database"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.7",
  "license": "UNLICENSED"
}
